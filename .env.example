# Database
DATABASE_URL=postgres://postgres:password@localhost:5433/access_check
DB_HOST=localhost
DB_PORT=5433
DB_NAME=access_check
DB_USER=postgres
DB_PASSWORD=password

# JWT — REQUIRED: must be 32+ chars and not a known weak default (server will refuse to start otherwise)
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_-base64_48
JWT_EXPIRES_IN=8h

# Server
PORT=3001
NODE_ENV=development

# Admin default credentials (used only for initial seed)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin1234!

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# File upload
MAX_UPLOAD_SIZE_MB=5

# CORS — comma-separated list of allowed origins for production
# e.g. CORS_ORIGINS=https://admin.yourdomain.com,https://gate.yourdomain.com
CORS_ORIGINS=http://localhost:3002,http://localhost:3003

# Domain (used by Caddy for automatic HTTPS — set to your real domain in production)
DOMAIN=your-domain.com
